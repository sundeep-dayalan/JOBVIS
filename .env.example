# ── JOBVIS environment variables ─────────────────────────────────────────────
# Copy this file to `.env` in the repo root and fill in the values you need:
#     cp .env.example .env
# `.env` is gitignored and must never be committed.
#
# You only need the API key for the ACTIVE LLM provider selected in
# config/llm_config.yml (the entry marked `active: true`). Local providers
# (ollama, mlx) require no key at all.

# Google Gemini — required when the active provider is "gemini".
# Create a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq — required when the active provider is "groq".
# Create a key at: https://console.groq.com/keys
GROQ_API_KEY=
